{
  "version": "1.0",
  "_comment": "已定制:使用 NVIDIA NIM 免费 API 调 DeepSeek;信源聚焦 AI 领域;中文输出。",

  "ai": {
    "provider": "deepseek",
    "model": "z-ai/glm-5.1",
    "base_url": "https://integrate.api.nvidia.com/v1",
    "api_key_env": "NVIDIA_API_KEY",
    "temperature": 0.5,
    "max_tokens": 8192,
    "throttle_sec": 5.0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh"]
  },

  "sources": {
    "rss": [
      { "name": "OpenAI",             "url": "https://openai.com/news/rss.xml",                                    "enabled": true, "category": "ai-news" },
      { "name": "Google AI",          "url": "https://blog.google/technology/ai/rss/",                             "enabled": true, "category": "ai-news" },
      { "name": "Anthropic (mirror)", "url": "https://raw.githubusercontent.com/taobojlen/anthropic-rss-feed/main/anthropic_news_rss.xml", "enabled": true, "category": "ai-news" },
      { "name": "Hugging Face",       "url": "https://huggingface.co/blog/feed.xml",                               "enabled": true, "category": "ai-tools" },
      { "name": "The Verge AI",       "url": "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml",  "enabled": true, "category": "ai-news" },
      { "name": "TechCrunch AI",      "url": "https://techcrunch.com/category/artificial-intelligence/feed/",      "enabled": true, "category": "ai-news" },
      { "name": "MarkTechPost",       "url": "https://www.marktechpost.com/feed/",                                 "enabled": true, "category": "ai-news" },
      { "name": "VentureBeat AI",     "url": "https://venturebeat.com/category/ai/feed/",                          "enabled": true, "category": "ai-news" },
      { "name": "The Decoder",        "url": "https://the-decoder.com/feed/",                                      "enabled": true, "category": "ai-news" },
      { "name": "Synced",             "url": "https://syncedreview.com/feed/",                                     "enabled": true, "category": "ai-news" },
      { "name": "BDTechTalks",        "url": "https://bdtechtalks.com/feed/",                                      "enabled": true, "category": "ai-news" },
      { "name": "Ahead of AI",        "url": "https://magazine.sebastianraschka.com/feed",                         "enabled": true, "category": "ai-research" },
      { "name": "Simon Willison",     "url": "https://simonwillison.net/atom/everything/",                         "enabled": true, "category": "ai-tools" },
      { "name": "arXiv cs.AI",        "url": "https://rss.arxiv.org/rss/cs.AI",                                    "enabled": false, "category": "ai-research" }
    ],

    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },

    "reddit": {
      "enabled": true,
      "subreddits": [
        { "subreddit": "LocalLLaMA",      "enabled": true },
        { "subreddit": "MachineLearning", "enabled": true }
      ]
    }
  },

  "filtering": {
    "ai_score_threshold": 6.0,
    "max_items": 20,
    "drop_signal_types": ["pr_hype", "rehash", "funding_fluff", "low_signal"]
  }
}
